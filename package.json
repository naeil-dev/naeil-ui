{
  "name": "@naeil/ui",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./ui": {
      "import": "./dist/components/ui/index.js",
      "types": "./dist/components/ui/index.d.ts"
    },
    "./utils": {
      "import": "./dist/lib/utils.js",
      "types": "./dist/lib/utils.d.ts"
    },
    "./theme.css": "./src/styles/theme.css",
    "./globals.css": "./src/app/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./i18n/*": "./src/i18n/*.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "tsup",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "build:tokens": "tsx scripts/build-tokens.ts",
    "check:contrast": "tsx scripts/check-contrast.ts"
  },
  "peerDependencies": {
    "next": "^15 || ^16",
    "next-intl": "^4",
    "next-themes": "^0.4",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.7",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "pretendard": "^1.3.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reading-time": "^1.5.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist/",
    "src/styles/",
    "src/app/globals.css",
    "messages/"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "style-dictionary",
      "@bundled-es-modules/glob"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/naeil-dev/design-system"
  },
  "description": "Design system for naeil.dev — React components, design tokens, and i18n support built with Next.js, Radix UI, and Tailwind CSS.",
  "keywords": [
    "design-system",
    "react",
    "components",
    "tailwindcss",
    "radix-ui",
    "next.js",
    "i18n"
  ],
  "homepage": "https://naeil.dev"
}
